# GitHub 私有仓库配置
# 在服务器的 .env 文件中设置这些值（不要提交 .env 到 Git）

# 仓库地址（格式: owner/repo）
GITHUB_REPO=zerx-lab/FluxDown

# GitHub Personal Access Token (classic)
# 需要 repo 权限（读取私有仓库 Release）
# 创建地址: https://github.com/settings/tokens
GITHUB_TOKEN=

# GitHub Webhook 签名密钥（与 GitHub Webhook 设置中的 Secret 一致）
GITHUB_WEBHOOK_SECRET=***REMOVED***
# 可选：GitHub Projects 专用 Token（需要 read:project scope）
GITHUB_PROJECT_TOKEN=***REMOVED***
# GitHub Projects 看板编号（URL 末尾的数字，如 /projects/4 则填 4）
GITHUB_PROJECT_NUMBER=4
# Projects 所属账号（用户名或组织名，如 zerx-lab）
GITHUB_PROJECT_OWNER=zerx-lab
# SMTP 邮件配置（用于 Webhook 触发的反馈回复通知）
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
# 自由付款支付网关（zerx pay gateway）
# Base URL（含 /api 前缀），本地测试如 http://localhost:5173/api，生产如 https://pay.zerx.dev/api
PAY_GATEWAY_URL=http://localhost:5173/api
# 应用 ID（CreateApp 时分配）
PAY_APP_ID=app_451a2bb4d507c3a7
# 应用密钥（仅服务端使用，绝不暴露给前端；CreateApp 时一次性返回）
PAY_APP_SECRET=
# 异步回调：在支付平台后台为该 app 配置 notify_url 为 https://<本站域名>/api/pay/notify
# （服务端验签后标记订单已支付，前端轮询 /api/pay/status 显示感谢页；无需额外 env）

# Cloudflare R2 对象存储（用于下载文件加速分发，改善中国大陆下载速度）
# 创建地址: https://dash.cloudflare.com/ → R2 → 管理 R2 API 令牌
# 权限: 对象读和写，仅应用于特定存储桶
CF_R2_ACCESS_KEY_ID=***REMOVED***
CF_R2_SECRET_ACCESS_KEY=***REMOVED***
# R2 S3 兼容终结点（格式: https://<accountid>.r2.cloudflarestorage.com）
CF_R2_ENDPOINT=https://***REMOVED***.r2.cloudflarestorage.com
# R2 存储桶名称
CF_R2_BUCKET=flux-down
# R2 公开访问域名（绑定自定义域后填写，格式: https://dl.fluxdown.app）
CF_R2_PUBLIC_URL=https://dw-fluxdown.zerx.dev

# Cloudflare API Token（用于查询 R2 下载统计，Account ID 自动从 CF_R2_ENDPOINT 解析）
# 创建地址: https://dash.cloudflare.com/profile/api-tokens
# 权限: Account Analytics:Read
CF_API_TOKEN=***REMOVED***
