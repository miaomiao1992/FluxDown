# GitHub 私有仓库配置
# 在 Vercel Dashboard → Settings → Environment Variables 中设置这些值

# 仓库地址（格式: owner/repo）
GITHUB_REPO=your-username/x_down

# GitHub Personal Access Token (classic)
# 需要 repo 权限（读取私有仓库 Release）
# 创建地址: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_WEBHOOK_SECRET=xxxxxxxxxx
SMTP_HOST=465
SMTP_USER=xxxxxxxxxxx@163.com
SMTP_PASS=xxxxxxxxxxx
